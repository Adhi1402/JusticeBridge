# Copy this file to  ../.env  (repo root) and fill in your key.
# The .env file is git-ignored — never commit real keys.

# Sarvam AI — powers cloud STT (Saaras v3), OCR (Document Intelligence),
# TTS (Bulbul v3), and translation (sarvam-translate:v1). Get a key at
# https://dashboard.sarvam.ai
SARVAM_API_KEY=sk_your_key_here

# ---- optional backend overrides (defaults shown) ----
# JB_ASR_BACKEND=sarvam         # sarvam | whisper
# JB_VISION_BACKEND=sarvam      # sarvam | tesseract
# JB_TTS_BACKEND=sarvam         # sarvam | pyttsx3 | none
# JB_TRANSLATION_BACKEND=sarvam # sarvam | indictrans2 (on-device) | none
# JB_LLM_BACKEND=geniex         # geniex | onnx_qnn | openai | extractive
# JB_DISTRICT=Kanchipuram

# ---- fallback control (see README "Backends at a glance") ----
# JB_ALLOW_LLM_FALLBACK=1           # 0 = surface "unavailable" instead of silently degrading
# JB_ALLOW_REASONING_FALLBACK=1     # per-agent override
# JB_ALLOW_PLANNER_FALLBACK=1       # per-agent override

# ---- optional LLM-assisted upgrades (additive only, off by default) ----
# JB_LLM_ASSISTED_GROUNDING=0
# JB_LLM_ASSISTED_ELIGIBILITY=0
