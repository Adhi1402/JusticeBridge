# Copy this file to  ../.env  (repo root) if you want to override any
# defaults below. JusticeBridge runs fully offline out of the box — no API
# keys required. The .env file is git-ignored.

# ---- optional backend overrides (defaults shown) ----
# JB_ASR_BACKEND=whisper           # whisper (on-device only)
# JB_VISION_BACKEND=tesseract      # tesseract (on-device only)
# JB_TTS_BACKEND=pyttsx3           # pyttsx3 | none
# JB_TRANSLATION_BACKEND=indictrans2  # indictrans2 (on-device) | none
# JB_LLM_BACKEND=onnx              # onnx (default, CPU) | geniex | onnx_qnn | openai | extractive
# JB_ONNX_MODEL_REPO=microsoft/Phi-3-mini-4k-instruct-onnx
# JB_ONNX_MODEL_SUBFOLDER=cpu_and_mobile/cpu-int4-rtn-block-32-acc-level-4
# JB_ONNX_MODEL_CACHE_ROOT=<repo>/justicebridge/models/phi3-mini-onnx
# JB_DISTRICT=Kanchipuram

# ---- fallback control (see README "Backends at a glance") ----
# JB_ALLOW_LLM_FALLBACK=1           # 0 = surface "unavailable" instead of silently degrading
# JB_ALLOW_REASONING_FALLBACK=1     # per-agent override
# JB_ALLOW_PLANNER_FALLBACK=1       # per-agent override

# ---- optional LLM-assisted upgrades (additive only, off by default) ----
# JB_LLM_ASSISTED_GROUNDING=0
# JB_LLM_ASSISTED_ELIGIBILITY=0
